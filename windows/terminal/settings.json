  "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
  "focusFollowMouse": true,
  "initialCols": 80,
  "initialRows": 38,
  "keybindings": [
    {
      "id": "User.sendInput.8882FD6D",
      "keys": "shift+enter"
    },
    {
      "id": "User.splitPane.A6751878",
      "keys": "alt+shift+d"
    },
    {
      "id": "User.find",
      "keys": "ctrl+shift+f"
    },
    {
      "id": "User.paste",
      "keys": "ctrl+v"
    },
    {
      "id": "User.copy.644BA8F2",
      "keys": "ctrl+c"
    }
